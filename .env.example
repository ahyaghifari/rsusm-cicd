APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

ADMIN_PATH=manage              # Ganti ke path custom di production

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false          # Set true di production
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false    # Set true di production (HTTPS)

TRUSTED_PROXIES=               # IP load balancer/proxy di production

BROADCAST_CONNECTION=reverb         # reverb = WebSocket realtime (chat konsultasi dokter)

# Reverb (WebSocket server) — generate via `php artisan reverb:install`
# Catatan: proses `php artisan reverb:start` harus selalu berjalan di production (Supervisor/systemd)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Ketersediaan Rawat Inap — base URL API Ranap tanpa kode RS & tanpa trailing slash.
# Kosongkan untuk fallback ke fixture lokal (storage/app/mock/ranap-ketersediaan.json).
# Kode identifier per RS diisi di kolom rumah_sakit.ranap_kode_api, bukan di .env.
RANAP_API_BASE_URL=

# Live Antrian Poliklinik — base URL-nya dari kolom rumah_sakit.link_antrian (per RS),
# bukan env. Kredensial Basic Auth di bawah ini global (sama untuk semua RS).
ANTRIAN_API_USERNAME=
ANTRIAN_API_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
